PORT=3000

# Path to the real SIGMA-MDX bot source (relative to sigma-mdx/ or absolute)
# Default: ../SIGMA-MDX-repo (the cloned repo sitting next to this project)
# BOT_SOURCE_DIR=/absolute/path/to/SIGMA-MDX-repo
NODE_ENV=development
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# GitHub OAuth App credentials
# Create one at: https://github.com/settings/developers -> OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/github/callback

# Shared bot limits
MAX_SHARED_SESSIONS=20
SESSION_TTL_HOURS=24
